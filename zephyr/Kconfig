menuconfig DANP_FTP
    bool "Enable DANP File Transfer Protocol (FTP)"
    help
    Enable the DANP File Transfer Protocol (FTP) library.

if DANP_FTP
    config DANP_FTP_LOG_LEVEL
        int "DANP_FTP log level"
        default 3
        help
        Set the log level for the DANP_FTP (0-4).
    config DANP_FTP_SERVICE_PORT
        int "DANP FTP service port id"
        default 21
        help
        Ser the service port id for DANP FTP
    config DANP_FTP_SERVICE_TIMEOUT_MS
        int "DANP FTP service timeout in milliseconds"
        default 8000
        help
        Set the service timeout for DANP FTP in milliseconds.
endif # DANP_FTP
